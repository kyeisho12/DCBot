# =============================================================================
# Required: copy this file to .env and fill in all values. See SETUP.md for
# step-by-step instructions on where to get each key.
# =============================================================================

# --- Discord (required for bot and for deploy-commands.js) ---
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_guild_id_here

# --- Google Sheets (required for time tracking) ---
# Get these from a Service Account JSON key + spreadsheet URL. See SETUP.md.
GOOGLE_SHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- Optional ---
# SHEET_NAME=Hours
